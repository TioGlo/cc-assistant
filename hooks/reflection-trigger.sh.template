#!/bin/bash
# Self-improving reflection trigger.
# Register as PostToolUse hook (matcher: "") in .claude/settings.json.
# Counts tool calls per session. After THRESHOLD calls, forces a reflection.
# Counter resets after reflection is triggered.

THRESHOLD=15
COUNTER_FILE="/tmp/claude-si-counter-$$"

# Use parent PID as session identifier (claude's PID stays constant within a session)
PPID_FILE="/tmp/claude-si-ppid"
CURRENT_PPID=$(ps -o ppid= $$ 2>/dev/null | tr -d ' ')

# Reset counter if this is a new session (different parent PID)
if [ -f "$PPID_FILE" ]; then
  LAST_PPID=$(cat "$PPID_FILE")
  if [ "$CURRENT_PPID" != "$LAST_PPID" ]; then
    rm -f /tmp/claude-si-counter-* 2>/dev/null
  fi
fi
echo "$CURRENT_PPID" > "$PPID_FILE"

# Use a stable counter file keyed to the parent PID
COUNTER_FILE="/tmp/claude-si-counter-${CURRENT_PPID}"

# Increment counter
COUNT=0
if [ -f "$COUNTER_FILE" ]; then
  COUNT=$(cat "$COUNTER_FILE")
fi
COUNT=$((COUNT + 1))
echo "$COUNT" > "$COUNTER_FILE"

# After threshold, force reflection and reset
if [ "$COUNT" -ge "$THRESHOLD" ]; then
  echo "0" > "$COUNTER_FILE"
  cat <<'EOF'
[Self-improving — REFLECTION REQUIRED]
You have made 15+ tool calls. Before continuing, you MUST answer two questions:

QUESTION 1 — CORRECTIONS: Were there errors, retries, course corrections, or discoveries?
If yes → log them to self-improving/corrections.md (one line per learning)
If an approach worked well → log it as a positive signal

QUESTION 2 — SKILL: Did you just execute a non-trivial multi-step workflow that required
trial and error, domain knowledge, or a specific sequence of actions to get right?
If yes → write it as a reusable skill. Create a markdown file in self-improving/domains/
or self-improving/projects/ with:
  - What the task was
  - The exact steps that worked (not the ones that didn't)
  - Any gotchas or prerequisites
  - When to use this approach again
Name it descriptively (e.g., "instagram-carousel-posting.md", "comfyui-batch-generation.md").
Only write a skill if the workflow was genuinely non-obvious — don't skill-ify simple tasks.

This is not optional. Answer both questions, then proceed.
EOF
fi
