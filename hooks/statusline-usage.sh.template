#!/bin/bash
# Statusline script: captures rate_limits to a shared file and displays usage.
# Other processes (bot, heartbeat, cron jobs) can read the file.
#
# Anthropic has repeatedly changed the meaning of the rolling-window
# rate_limits field (5h/7d in early 2026, 5h/24h mid-April, back to 5h/7d
# late April). Rather than chase the field name, we derive the label from
# `resets_at` itself — the time-until-reset is a reliable proxy for the
# window length, and reads correctly no matter what Anthropic calls the
# field next month.

USAGE_FILE="$HOME/.assistant/usage-status.json"
input=$(cat)

# Extract fields
MODEL=$(echo "$input" | jq -r '.model.display_name // "?"')
PCT=$(echo "$input" | jq -r '.context_window.used_percentage // 0' | cut -d. -f1)
RATE_LIMITS=$(echo "$input" | jq -c '.rate_limits // empty')

# Pick the window label from a future-resets_at delta. This is robust to
# Anthropic renaming the JSON key or repurposing it again.
window_label() {
  local resets_at="$1"
  if [ -z "$resets_at" ] || [ "$resets_at" = "null" ]; then
    echo "?"
    return
  fi
  local now seconds
  now=$(date +%s)
  seconds=$((resets_at - now))
  if [ "$seconds" -le 0 ]; then
    echo "?"
  elif [ "$seconds" -lt 43200 ]; then        # < 12h → label by hours remaining
    echo "$((seconds / 3600))h"
  elif [ "$seconds" -lt 129600 ]; then       # 12-36h → 24h window
    echo "24h"
  else                                       # ≥ 36h → days, rounded
    echo "$(( (seconds + 43200) / 86400 ))d"
  fi
}

if [ -n "$RATE_LIMITS" ]; then
  FIVE_HOUR=$(echo "$input" | jq -r '.rate_limits.five_hour.used_percentage // "N/A"')
  # Cycle through the plausible names Anthropic has used or might use for
  # the longer-window field. First match wins.
  LONG=$(echo "$input" | jq -r '.rate_limits.seven_day.used_percentage // .rate_limits.twenty_four_hour.used_percentage // .rate_limits.one_day.used_percentage // .rate_limits.daily.used_percentage // .rate_limits.weekly.used_percentage // "N/A"')
  FIVE_RESETS=$(echo "$input" | jq -r '.rate_limits.five_hour.resets_at // null')
  LONG_RESETS=$(echo "$input" | jq -r '.rate_limits.seven_day.resets_at // .rate_limits.twenty_four_hour.resets_at // .rate_limits.one_day.resets_at // .rate_limits.daily.resets_at // .rate_limits.weekly.resets_at // null')

  LONG_LABEL=$(window_label "$LONG_RESETS")

  cat > "$USAGE_FILE" <<EOF
{
  "updated_at": "$(date -Iseconds)",
  "model": "$MODEL",
  "five_hour_pct": $FIVE_HOUR,
  "long_window_pct": $LONG,
  "long_window_label": "$LONG_LABEL",
  "five_hour_resets_at": $FIVE_RESETS,
  "long_window_resets_at": $LONG_RESETS,
  "context_pct": $PCT
}
EOF

  # Color the long-window number: green < 60, yellow 60-80, red > 80
  if [ "$LONG" != "N/A" ]; then
    L_INT=${LONG%.*}
    if [ "$L_INT" -ge 80 ] 2>/dev/null; then
      COLOR="\033[31m"
    elif [ "$L_INT" -ge 60 ] 2>/dev/null; then
      COLOR="\033[33m"
    else
      COLOR="\033[32m"
    fi
    RESET="\033[0m"
    echo -e "5h: ${FIVE_HOUR}% | ${LONG_LABEL}: ${COLOR}${LONG}%${RESET} | ctx: ${PCT}%"
  else
    echo "5h: ${FIVE_HOUR}% | ${LONG_LABEL}: ${LONG}% | ctx: ${PCT}%"
  fi
else
  echo "[$MODEL] ctx: ${PCT}%"
fi
