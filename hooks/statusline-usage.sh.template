#!/bin/bash
# Statusline script: captures rate_limits to a shared file and displays usage.
# Other processes (bot, heartbeat, cron jobs) can read the file.
#
# NOTE: As of ~April 2026 Anthropic silently repurposed the `seven_day`
# rate_limits field to be a rolling 24-hour window. The JSON schema still
# calls it `seven_day`, but `resets_at` is 24h out, not 7d. We label it "24h"
# everywhere the human sees it and in the downstream JSON keys.

USAGE_FILE="$HOME/.assistant/usage-status.json"
input=$(cat)

# Extract fields
MODEL=$(echo "$input" | jq -r '.model.display_name // "?"')
PCT=$(echo "$input" | jq -r '.context_window.used_percentage // 0' | cut -d. -f1)
RATE_LIMITS=$(echo "$input" | jq -c '.rate_limits // empty')

# Write rate_limits + metadata to shared file
if [ -n "$RATE_LIMITS" ]; then
  FIVE_HOUR=$(echo "$input" | jq -r '.rate_limits.five_hour.used_percentage // "N/A"')
  # Anthropic still emits this as `seven_day` but the window is 24h.
  # Try the plausible new key names too, in case they rename it later.
  DAILY=$(echo "$input" | jq -r '.rate_limits.twenty_four_hour.used_percentage // .rate_limits.one_day.used_percentage // .rate_limits.daily.used_percentage // .rate_limits.seven_day.used_percentage // "N/A"')
  FIVE_RESETS=$(echo "$input" | jq -r '.rate_limits.five_hour.resets_at // null')
  DAILY_RESETS=$(echo "$input" | jq -r '.rate_limits.twenty_four_hour.resets_at // .rate_limits.one_day.resets_at // .rate_limits.daily.resets_at // .rate_limits.seven_day.resets_at // null')

  cat > "$USAGE_FILE" <<EOF
{
  "updated_at": "$(date -Iseconds)",
  "model": "$MODEL",
  "five_hour_pct": $FIVE_HOUR,
  "twenty_four_hour_pct": $DAILY,
  "five_hour_resets_at": $FIVE_RESETS,
  "twenty_four_hour_resets_at": $DAILY_RESETS,
  "context_pct": $PCT
}
EOF

  # Color code on the 24h window: green < 60, yellow 60-80, red > 80
  if [ "$DAILY" != "N/A" ]; then
    D_INT=${DAILY%.*}
    if [ "$D_INT" -ge 80 ] 2>/dev/null; then
      COLOR="\033[31m"  # red
    elif [ "$D_INT" -ge 60 ] 2>/dev/null; then
      COLOR="\033[33m"  # yellow
    else
      COLOR="\033[32m"  # green
    fi
    RESET="\033[0m"
    echo -e "5h: ${FIVE_HOUR}% | 24h: ${COLOR}${DAILY}%${RESET} | ctx: ${PCT}%"
  else
    echo "5h: ${FIVE_HOUR}% | 24h: ${DAILY}% | ctx: ${PCT}%"
  fi
else
  echo "[$MODEL] ctx: ${PCT}%"
fi
